<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Signup"
    android:orientation="vertical"
    android:background="#DD353E80">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✨ Create Account "
        android:textSize="47sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textStyle="italic|bold"
        android:textColor="#4E0436"
        android:padding="12dp"
        android:background="@drawable/shape"/>

<!--      Below is a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">



<!--            bellow is the edit text for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter your Username"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:fontFamily="sans-serif"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>

 <!--            bellow is the edit text for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your Email Address"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:inputType="textEmailAddress"
                android:fontFamily="sans-serif"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>

 <!--            bellow is the edit text for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your password"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:fontFamily="sans-serif"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>

<!--            bellow is the edit text for phone number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter your phone number"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#070707"
                android:fontFamily="sans-serif"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="7dp"/>

<!--            below is the sign up button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✨ Sign Up ✨"
                android:textStyle="italic"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:backgroundTint="#FF6EC7"
                android:textColor="#000"
                android:layout_marginTop="22dp"
                android:id="@+id/signupbtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already have an account? Signin"
                android:textAlignment="center"
                android:textColor="#26159d"
                android:textSize="23sp"
                android:layout_marginTop="12dp"
                android:id="@+id/signintxt"
                android:fontFamily="sans-serif-black"/>

        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>