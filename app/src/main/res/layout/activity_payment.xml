<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PaymentActivity"
    android:orientation="vertical"
    android:background="#F1FBE7">

<!--    bellow is text view -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Payment with Mpesa"
        android:textSize="42sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:fontFamily="cursive"
        android:layout_marginTop="10dp"
        android:textColor="#094"/>

<!--    below is  a card view that holds all our contents-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="15dp">

<!--        below is a linear layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#7F993B6A"
            android:gravity="center">

<!--            below is a Textview where thw name of the product shall be dinded /attached -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="25sp"
                android:textAlignment="center"
                android:textStyle="bold|italic"
                android:id="@+id/txtProductName"
                android:textColor="#000"/>

<!--            below is an image view for the product image-->
            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

<!--            below is the text view for product description-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Description"
                android:textSize="20sp"
                android:textAlignment="center"
                android:textStyle="bold|italic"
                android:textColor="#000"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:id="@+id/txtProductDescription"/>



<!--         below is the text view for the product_cost-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="Kes 1000"
                android:textSize="30sp"
                android:textAlignment="center"
                android:textStyle="bold|italic"
                android:textColor="#1135F4"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

<!--            below is an edit text for entering mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter phone number eg 254789849585"
                android:textColorHint="#000"
                android:textSize="20sp"
                android:textColor="#748"
                android:fontFamily="sans-serif"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#F5FFF5"
                android:padding="13dp"/>

<!--             below is a button tp complete the payment action-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete Payment"
                android:textStyle="italic"
                android:textSize="25sp"
                android:id="@+id/pay"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:backgroundTint="#8210b9"
                android:textColor="#000"
                android:layout_marginTop="15dp"/>







        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>