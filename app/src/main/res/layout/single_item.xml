<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

<!--    Beliw is a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_margin="10dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="12dp">

<!--        Below is another linear layout that detects how the contents will be aligned-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#8EEFE7">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="Product Name"
                android:textSize="25sp"
                android:textAlignment="center"
                android:textStyle="bold|italic"
                android:textColor="#092CEB"
                android:padding="5dp"
                android:fontFamily="sans-serif"/>

<!--            below is our product-image-->
            <ImageView
                android:id="@+id/product_photo"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:padding="5dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="3dp"/>

<!--            below is a textview of the product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="Kes 500"
                android:textSize="25sp"
                android:layout_marginLeft="10dp"
                android:textStyle="bold|italic"
                android:textColor="#1E319E"
                android:layout_marginTop="5dp"/>

<!--            below is a textview for the product_description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:text="Description of the product"
                android:textSize="20sp"
                android:layout_marginLeft="10dp"
                android:textStyle="bold|italic"
                android:textColor="#000"
                android:layout_marginTop="5dp"/>

<!--            below is a the purchase button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:text="Purchase now"
                android:textSize="20sp"
                android:layout_marginLeft="70dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="70dp"
                android:backgroundTint="#4b1889"
                android:textColor="#fff"/>



        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>